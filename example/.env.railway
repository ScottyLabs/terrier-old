# Terrier — Railway environment template
#
# Copy these variables into your Terrier service in the Railway dashboard
# (Variables tab), or use "Raw Editor". Do not commit real secrets.
#
# Railway injects PORT automatically — do not set it unless you have a reason.
# Reference other services with Railway variables, e.g. ${{Postgres.DATABASE_URL}}
#
# See RAILWAY.md for step-by-step setup of each service.

# -----------------------------------------------------------------------------
# Terrier (this service)
# -----------------------------------------------------------------------------

# Public URL users visit (your Terrier service custom domain or *.up.railway.app)
APP_BASE_URL=https://terrier.example.com

# Bind on all interfaces inside the container (required on Railway)
IP=0.0.0.0

# -----------------------------------------------------------------------------
# PostgreSQL (Railway Postgres plugin → reference in Terrier service)
# -----------------------------------------------------------------------------
# Example after linking Postgres to Terrier:
# DATABASE_URL=${{Postgres.DATABASE_URL}}
#
# Or paste the private URL from the Postgres service Variables tab:
DATABASE_URL=postgres://postgres:PASSWORD@postgres.railway.internal:5432/railway

# -----------------------------------------------------------------------------
# Redis (Railway Redis plugin → reference in Terrier service)
# -----------------------------------------------------------------------------
# Example after linking Redis to Terrier:
# REDIS_URL=${{Redis.REDIS_URL}}
#
# Or paste from the Redis service Variables tab:
REDIS_URL=redis://default:PASSWORD@redis.railway.internal:6379

# -----------------------------------------------------------------------------
# MinIO / object storage (separate Railway service or external S3)
# -----------------------------------------------------------------------------
# Internal URL — Terrier server talks to MinIO over Railway private network
MINIO_ENDPOINT=http://minio.railway.internal:9000

# Public URL — browsers load uploaded files (banners, resumes, etc.) from here
# Use the MinIO service's public Railway domain or your custom domain
MINIO_PUBLIC_ENDPOINT=https://minio.example.com

MINIO_ROOT_USER=terrier
MINIO_ROOT_PASSWORD=CHANGE_ME_use_openssl_rand_base64_24
MINIO_BUCKET=terrier

# -----------------------------------------------------------------------------
# OIDC (external identity provider — not hosted on Railway)
# -----------------------------------------------------------------------------
OIDC_ISSUER=https://your-idp.example.com/realms/terrier
OIDC_CLIENT_ID=terrier
OIDC_CLIENT_SECRET=CHANGE_ME_from_your_idp

# Register this redirect URI in your OIDC client:
#   {APP_BASE_URL}/auth/callback
# Mobile (if applicable): terrier://auth/callback

# -----------------------------------------------------------------------------
# Admins
# -----------------------------------------------------------------------------
ADMIN_EMAILS=you@example.com,other-admin@example.com

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY=
# POSTHOG_KEY=
# POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Logging (recommended for production)
# -----------------------------------------------------------------------------
RUST_LOG=info,terrier=debug
RUST_BACKTRACE=1
